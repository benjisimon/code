## geoassist config
## Copy this file to config and fill in your API keys.

# OpenRouteService API key (free tier available)
# Get one at: https://openrouteservice.org/dev/#/signup
ORS_API_KEY=your_ors_api_key_here

# Mapbox token (used for map image export)
# Get one at: https://account.mapbox.com/access-tokens/
MAPBOX_TOKEN=your_mapbox_token_here

# Google Maps API key (used for Street View export)
# Get one at: https://console.cloud.google.com/
GOOGLE_MAPS_KEY=your_google_maps_key_here
